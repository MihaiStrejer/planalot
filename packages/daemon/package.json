{
  "name": "@planalot/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "planalot": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts daemon",
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node scripts/copy-web.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@planalot/cc": "workspace:*",
    "@planalot/codex": "workspace:*",
    "@planalot/pi": "workspace:*",
    "@planalot/shared": "workspace:*",
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
